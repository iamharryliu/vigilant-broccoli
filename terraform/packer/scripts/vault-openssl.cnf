[ req ]
default_bits = 2048
prompt = no
default_md = sha256
distinguished_name = dn
x509_extensions = v3_ext

[ dn ]
CN = vb-vault

[ alt_names ]
DNS.1 = vb-vault
DNS.2 = localhost
IP.1 = 127.0.0.1
IP.2 = 10.0.0.1

[ v3_ext ]
subjectAltName = @alt_names
basicConstraints = CA:FALSE
keyUsage = digitalSignature, keyEncipherment
extendedKeyUsage = serverAuth
