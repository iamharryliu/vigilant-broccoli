{
  "private": true,
  "scripts": {
    "install-all": "npm-recursive-install",
    "format": "prettier --write .",
    "format:commit": "prettier --write",
    "gcp:login": "gcloud auth login && gcloud config set project vigilant-broccoli && gcloud auth application-default login",
    "vm:ssh": "gcloud compute ssh vb-free-vm --zone=us-east1-b --tunnel-through-iap",
    "vm:status": "gcloud compute instances describe vb-free-vm --zone=us-east1-b --format='value(status)'",
    "vm:stop": "gcloud compute instances stop vb-free-vm --zone=us-east1-b",
    "vm:start": "gcloud compute instances start vb-free-vm --zone=us-east1-b",
    "vm:post-init": "./terraform/packer/scripts/run-vault-post-init.sh",
    "vm:regen-cert": "./terraform/packer/scripts/run-vault-regen-cert.sh && npm run vm:update-wg",
    "vm:update-wg": "./terraform/packer/scripts/run-update-wg-endpoint.sh",
    "vm:vault:test-local-connection": "gcloud compute ssh vb-free-vm --zone=us-east1-b --tunnel-through-iap --command='export VAULT_ADDR=https://127.0.0.1:8200 VAULT_SKIP_VERIFY=true && vault status && echo \"✓ Vault is accessible\"'",
    "vm:vault:unseal": "./terraform/packer/scripts/run-vault-unseal.sh",
    "vm:vault:seal": "./terraform/packer/scripts/run-vault-seal.sh",
    "vm:vault:save-secrets-local": "./terraform/packer/scripts/run-vault-get-secrets.sh",
    "vm:vault:set-secrets": "./terraform/packer/scripts/run-vault-set-secrets.sh",
    "secret-rotation:flyio": "./terraform/packer/scripts/rotate-fly-token.sh",
    "local:docker:restart": "docker compose -f infrastructure/local/docker-compose.yml restart"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamharryliu/vigilant-broccoli.git"
  },
  "bugs": {
    "url": "https://github.com/iamharryliu/vigilant-broccoli/issues"
  },
  "homepage": "https://github.com/iamharryliu/vigilant-broccoli#readme",
  "devDependencies": {
    "husky": "^4.3.8",
    "lint-staged": "^13.2.3",
    "prettier": "^3.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,html,css,scss,md}": [
      "npm run format:commit"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit.legacy": "lint-staged"
    }
  }
}
