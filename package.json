{
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "open:repo": "open https://github.com/iamharryliu/vigilant-broccoli",
    "open:repo:actions": "open https://github.com/iamharryliu/vigilant-broccoli/actions",
    "npm:packages": "open https://www.npmjs.com/settings/vigilant-broccoli/packages",
    "format": "prettier --write .",
    "format:commit": "prettier --write",
    "cloud:login": "pnpm gcp:login",
    "gcp:login": "gcloud auth login && gcloud config set project vigilant-broccoli && gcloud auth application-default login",
    "gh:login": "gh auth login && gh auth refresh -h github.com -s admin:org,delete_repo",
    "npm:login": "npm login",
    "oracle:config": "vim ~/.oci/config",
    "tf:plan": "eval $(./infrastructure/terraform/scripts/load-vault-tf-env.sh) && cd infrastructure/terraform && terraform plan",
    "tf:import": "eval $(./infrastructure/terraform/scripts/load-vault-tf-env.sh) && cd infrastructure/terraform && terraform import",
    "tf:apply": "eval $(./infrastructure/terraform/scripts/load-vault-tf-env.sh) && cd infrastructure/terraform && terraform apply && cd ../.. && ./infrastructure/terraform/scripts/post-apply.sh",
    "tf:post-apply": "./infrastructure/terraform/scripts/post-apply.sh",
    "tf:output": "cd infrastructure/terraform && terraform output",
    "oci:vm:ssh": "./scripts/shell/oci-ssh.sh oci_vm_public_ip",
    "oci:vm:sync-socket-token": "./infrastructure/terraform/packer/scripts/sync-socket-server-token.sh",
    "oci:gitea:ssh": "./scripts/shell/oci-ssh.sh oci_gitea_public_ip",
    "oci:gitea:backup:local": "./infrastructure/terraform/packer/scripts/backup-gitea.sh",
    "oci:gitea:backup:cloud": "./infrastructure/terraform/packer/scripts/backup-gitea.sh \"gs://vigilant-broccoli-backup/gitea-backup-$(date -u +%Y-%m-%d).zip\"",
    "oci:gitea:restore:local": "./infrastructure/terraform/packer/scripts/restore-gitea.sh",
    "oci:gitea:restore:cloud": "./infrastructure/terraform/packer/scripts/restore-gitea.sh",
    "oci:code-server:ssh": "./scripts/shell/oci-ssh.sh oci_code_server_public_ip",
    "oci:code-server:open": "open https://code.harryliu.dev",
    "oci:code-server:password": "eval $(./infrastructure/terraform/scripts/load-vault-tf-env.sh) && cd infrastructure/terraform && terraform state pull | jq -r '.resources[] | select(.type == \"random_password\" and .name == \"code_server_password\") | .instances[0].attributes.result' | pbcopy && echo 'Code server password copied to clipboard.'",
    "oci:code-server:logs": "./scripts/shell/oci-ssh.sh oci_code_server_public_ip 'sudo docker logs -f code-server'",
    "oci:code-server:logs:cloud-init": "./scripts/shell/oci-ssh.sh oci_code_server_public_ip 'tail -f /var/log/cloud-init-output.log'",
    "oci:code-server:replace": "eval $(./infrastructure/terraform/scripts/load-vault-tf-env.sh) && cd infrastructure/terraform && terraform apply -replace=oci_core_instance.code_server && ssh-keygen -R $(terraform output -raw oci_code_server_public_ip)",
    "oci:code-server:reset": "./scripts/shell/oci-ssh.sh oci_code_server_public_ip 'cd /opt/code-server && sudo docker compose down -v && sudo docker compose up -d'",
    "gh:actions:replace-code-server": "gh workflow run manual-replace-code-server --repo iamharryliu/vigilant-broccoli",
    "gcp:vm:ssh": "gcloud compute ssh vb-free-vm --zone=us-central1-a --tunnel-through-iap",
    "gcp:vm:status": "gcloud compute instances describe vb-free-vm --zone=us-central1-a --format='value(status)'",
    "gcp:vm:stop": "gcloud compute instances stop vb-free-vm --zone=us-central1-a",
    "gcp:vm:start": "gcloud compute instances start vb-free-vm --zone=us-central1-a",
    "gcp:vm:image:build": "cd infrastructure/terraform/packer && make init && make build",
    "gcp:vm:post-init": "./infrastructure/terraform/packer/scripts/run-vault-post-init.sh",
    "gcp:vm:regen-cert": "./infrastructure/terraform/packer/scripts/run-vault-regen-cert.sh && pnpm gcp:vm:update-wg",
    "gcp:vm:update-wg": "./infrastructure/terraform/packer/scripts/run-update-wg-endpoint.sh",
    "gcp:vm:vault:test-local-connection": "gcloud compute ssh vb-free-vm --zone=us-central1-a --tunnel-through-iap --command='export VAULT_ADDR=https://127.0.0.1:8200 VAULT_SKIP_VERIFY=true && vault status && echo \"✓ Vault is accessible\"'",
    "gcp:vm:vault:unseal": "./infrastructure/terraform/packer/scripts/run-vault-unseal.sh",
    "gcp:vm:vault:seal": "./infrastructure/terraform/packer/scripts/run-vault-seal.sh",
    "gcp:vm:vault:save-secrets-local": "./infrastructure/terraform/packer/scripts/run-vault-get-secrets.sh",
    "gcp:vm:vault:set-secrets": "./infrastructure/terraform/packer/scripts/run-vault-set-secrets.sh",
    "secret-rotation:all": "pnpm secret-rotation:flyio && pnpm secret-rotation:gitea && pnpm secret-rotation:profile-deploy-key && gh workflow run ci-rotate-secrets --repo iamharryliu/vigilant-broccoli -f confirm=rotate",
    "secret-rotation:flyio": "./infrastructure/terraform/packer/scripts/rotate-fly-token.sh",
    "secret-rotation:gitea": "./infrastructure/terraform/packer/scripts/rotate-gitea-token.sh",
    "secret-rotation:profile-deploy-key": "./scripts/ci/rotate-profile-deploy-key.sh",
    "secret-rotation:resend": "./infrastructure/terraform/packer/scripts/rotate-resend-key.sh",
    "local:install:machine-setup": "if [ \"$(uname)\" = Darwin ]; then zsh -c 'source setup/mac/install.sh'; else bash setup/linux/install.sh; fi",
    "local:docker:up": "docker compose -f infrastructure/local/docker-compose.yml up -d",
    "local:docker:down": "docker compose -f infrastructure/local/docker-compose.yml down",
    "local:docker:restart": "docker compose -f infrastructure/local/docker-compose.yml restart",
    "local:docker:reload": "docker compose -f infrastructure/local/docker-compose.yml down && docker compose -f infrastructure/local/docker-compose.yml up -d",
    "homelab:up": "docker compose -f infrastructure/homelab/docker-compose.yml up -d && tailscale serve --bg --tcp=80 tcp://127.0.0.1:22100",
    "homelab:down": "tailscale serve --tcp=80 off; docker compose -f infrastructure/homelab/docker-compose.yml down",
    "homelab:restart": "docker compose -f infrastructure/homelab/docker-compose.yml restart",
    "homelab:logs": "docker compose -f infrastructure/homelab/docker-compose.yml logs -f",
    "homelab:ps": "docker compose -f infrastructure/homelab/docker-compose.yml ps",
    "homelab:pull": "docker compose -f infrastructure/homelab/docker-compose.yml pull",
    "health-check": "./projects/nx-workspace/scripts/shell/health-check.sh",
    "gh:board:sync": "./scripts/shell/gh-board.sh sync",
    "gh:actions:deploy": "gh workflow run deploy --repo iamharryliu/vigilant-broccoli",
    "gh:actions:health-check": "gh workflow run ci-health-check --repo iamharryliu/vigilant-broccoli",
    "gh:actions:kill-services": "gh workflow run kill-services --repo iamharryliu/vigilant-broccoli",
    "gh:actions:security-cloudflare-access": "gh workflow run test-security-cloudflare-access --repo iamharryliu/vigilant-broccoli",
    "gh:actions:rotate-secrets": "gh workflow run ci-rotate-secrets --repo iamharryliu/vigilant-broccoli",
    "gh:actions:run-tests": "gh workflow run manual-run-tests --repo iamharryliu/vigilant-broccoli",
    "cheatsheet": "./scripts/shell/cheatsheet.sh",
    "audit": "python3 scripts/python/vuln_tree.py .",
    "nx:migrate": "cd projects/nx-workspace && nx migrate latest",
    "nx:migrate:run": "cd projects/nx-workspace && nx migrate --run-migrations"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamharryliu/vigilant-broccoli.git"
  },
  "bugs": {
    "url": "https://github.com/iamharryliu/vigilant-broccoli/issues"
  },
  "homepage": "https://github.com/iamharryliu/vigilant-broccoli#readme",
  "devDependencies": {
    "lint-staged": "^13.2.3",
    "prettier": "^3.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,html,css,scss,md}": [
      "pnpm format:commit"
    ]
  }
}
