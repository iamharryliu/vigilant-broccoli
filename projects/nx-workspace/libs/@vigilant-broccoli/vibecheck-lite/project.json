{
  "name": "@prettydamntired/vibecheck-lite",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/@vigilant-broccoli/vibecheck-lite/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/@vigilant-broccoli/vibecheck-lite",
        "tsConfig": "libs/@vigilant-broccoli/vibecheck-lite/tsconfig.lib.json",
        "packageJson": "libs/@vigilant-broccoli/vibecheck-lite/package.json",
        "main": "libs/@vigilant-broccoli/vibecheck-lite/src/index.ts",
        "assets": ["libs/@vigilant-broccoli/vibecheck-lite/*.md"]
      }
    },
    "publish": {
      "command": "cd libs/@vigilant-broccoli/vibecheck-lite && npm version patch && cd ../../../dist/libs/@vigilant-broccoli/vibecheck-lite && npm publish --access=public && cd ../../../",
      "dependsOn": ["build", "test", "lint"]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/@vigilant-broccoli/vibecheck-lite/jest.config.ts"
      }
    }
  }
}
