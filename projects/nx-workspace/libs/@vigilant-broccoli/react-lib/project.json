{
  "name": "@vigilant-broccoli/react-lib",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/@vigilant-broccoli/react-lib/src",
  "projectType": "library",
  "release": {
    "version": {
      "currentVersionResolver": "git-tag",
      "preserveLocalDependencyProtocols": false,
      "manifestRootsToUpdate": ["dist/{projectRoot}"]
    }
  },
  "tags": [],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "build": {
      "executor": "@nx/vite:build",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/libs/@vigilant-broccoli/react-lib"
      },
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "mode": "production"
        }
      }
    },
    "publish-package": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node ../../../../scripts/resolve-workspace-deps.js && VERSION=$(node -p \"require('./package.json').version\") && npm view $(node -p \"require('./package.json').name\")@$VERSION version 2>/dev/null && echo \"Skipping: version $VERSION already published\" || npm publish --access public --provenance",
        "cwd": "dist/libs/@vigilant-broccoli/react-lib",
        "forwardAllArgs": false
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/{projectRoot}"
      }
    }
  }
}
