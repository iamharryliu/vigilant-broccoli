{
  "name": "vb-manager-next",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/ui/vb-manager-next",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/next:build",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/ui/vb-manager-next",
        "webpack": true
      },
      "configurations": {
        "development": {
          "outputPath": "apps/ui/vb-manager-next"
        },
        "production": {}
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "defaultConfiguration": "development",
      "options": {
        "command": "node --import tsx scripts/fetch-secrets.ts 'cd apps/ui/vb-manager-next && next dev --webpack'",
        "env": {
          "NEXTAUTH_SECRET": "NEXTAUTH_SECRET",
          "NEXTAUTH_URL": "http://localhost:3000",
          "VB_EXPRESS_URL": "https://vb-express.fly.dev"
        }
      }
    },
    "serve:no-vault": {
      "executor": "@nx/next:server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "vb-manager-next:build",
        "dev": true,
        "webpack": true
      },
      "configurations": {
        "development": {
          "buildTarget": "vb-manager-next:build:development",
          "dev": true
        },
        "production": {
          "buildTarget": "vb-manager-next:build:production",
          "dev": false
        }
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/apps/ui/vb-manager-next"],
      "options": {
        "jestConfig": "apps/ui/vb-manager-next/jest.config.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx playwright test --config=apps/ui/vb-manager-next/e2e/playwright.config.ts"
      }
    },
    "e2e:headed": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx playwright test --config=apps/ui/vb-manager-next/e2e/playwright.config.ts --headed"
      }
    },
    "e2e:headed:slow": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx playwright test --config=apps/ui/vb-manager-next/e2e/playwright.config.ts --headed --project=slow"
      }
    },
    "pm2:start": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "tsx scripts/fetch-secrets.ts 'pm2 start apps/ui/vb-manager-next/ecosystem.config.js'"
      }
    },
    "pm2:reload": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "tsx scripts/fetch-secrets.ts 'pm2 reload apps/ui/vb-manager-next/ecosystem.config.js'"
      }
    },
    "pm2:delete": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pm2 delete vb-manager-next"
      }
    },
    "pm2:logs": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pm2 logs vb-manager-next"
      }
    },
    "pm2:status": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pm2 status"
      }
    }
  }
}
