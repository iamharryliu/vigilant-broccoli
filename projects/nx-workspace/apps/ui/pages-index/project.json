{
  "name": "pages-index",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/ui/pages-index/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "build": {
      "executor": "@nx/vite:build",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/pages-index"
      },
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "mode": "production"
        }
      }
    },
    "serve": {
      "executor": "@nx/vite:dev-server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "pages-index:build"
      },
      "configurations": {
        "development": {
          "buildTarget": "pages-index:build:development",
          "hmr": true
        },
        "production": {
          "buildTarget": "pages-index:build:production",
          "hmr": false
        }
      }
    },
    "deploy-github-pages": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "commands": [
          "mkdir -p ../../../_site",
          "cp -R ../../../dist/pages-index/. ../../../_site/"
        ],
        "parallel": false,
        "cwd": "{projectRoot}"
      }
    }
  }
}
