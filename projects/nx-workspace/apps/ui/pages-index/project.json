{
  "name": "pages-index",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/ui/pages-index/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "build": {
      "outputs": [
        "{projectRoot}/{options.outDir}",
        "{workspaceRoot}/dist/pages-index"
      ],
      "defaultConfiguration": "production",
      "options": {
        "outDir": "../../../dist/pages-index"
      },
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "mode": "production"
        }
      }
    },
    "serve": {
      "defaultConfiguration": "development",
      "configurations": {
        "development": {},
        "production": {}
      }
    },
    "deploy-github-pages": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "commands": [
          "mkdir -p ../../../_site",
          "cp -R ../../../dist/pages-index/. ../../../_site/"
        ],
        "parallel": false,
        "cwd": "{projectRoot}"
      }
    }
  }
}
