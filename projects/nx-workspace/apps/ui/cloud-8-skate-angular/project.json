{
  "name": "cloud-8-skate-angular",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/ui/cloud-8-skate-angular/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/ui/cloud-8-skate-angular",
        "index": "apps/ui/cloud-8-skate-angular/src/index.html",
        "browser": "apps/ui/cloud-8-skate-angular/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/ui/cloud-8-skate-angular/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          "apps/ui/cloud-8-skate-angular/src/favicon.ico",
          "apps/ui/cloud-8-skate-angular/src/assets",
          "apps/ui/cloud-8-skate-angular/src/robots.txt"
        ],
        "styles": [
          "apps/ui/cloud-8-skate-angular/src/styles.scss",
          "node_modules/@fortawesome/fontawesome-free/css/all.css"
        ],
        "scripts": []
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "2kb",
              "maximumError": "4kb"
            }
          ],
          "outputHashing": "all"
        },
        "production-env": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "2kb",
              "maximumError": "4kb"
            }
          ],
          "outputHashing": "all",
          "fileReplacements": [
            {
              "replace": "apps/ui/cloud-8-skate-angular/src/environments/environment.ts",
              "with": "apps/ui/cloud-8-skate-angular/src/environments/environment.production.ts"
            }
          ]
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true,
          "fileReplacements": [
            {
              "replace": "apps/ui/cloud-8-skate-angular/src/environments/environment.ts",
              "with": "apps/ui/cloud-8-skate-angular/src/environments/environment.development.ts"
            }
          ]
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "cloud-8-skate-angular:build:production"
        },
        "development": {
          "buildTarget": "cloud-8-skate-angular:build:development"
        }
      },
      "defaultConfiguration": "development",
      "continuous": true
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "buildTarget": "cloud-8-skate-angular:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "generate-sitemap": {
      "command": "node apps/ui/cloud-8-skate-angular/scripts/generate-sitemap.mjs",
      "dependsOn": ["build"]
    },
    "ensure-cf-project": {
      "command": "npx wrangler pages project list 2>&1 | grep -qw staging-cloud-8-skate-angular || npx wrangler pages project create staging-cloud-8-skate-angular --production-branch main"
    },
    "prune-deployments": {
      "command": "npx tsx scripts/prune-wrangler-deployments.ts staging-cloud-8-skate-angular 10"
    },
    "deploy": {
      "command": "npx wrangler pages deploy dist/apps/ui/cloud-8-skate-angular/browser --project-name staging-cloud-8-skate-angular",
      "dependsOn": [
        "generate-sitemap",
        "ensure-cf-project",
        "prune-deployments"
      ]
    },
    "manual-deploy": {
      "command": "npx wrangler pages deploy dist/apps/ui/cloud-8-skate-angular/browser --project-name staging-cloud-8-skate-angular",
      "dependsOn": [
        "generate-sitemap",
        "ensure-cf-project",
        "prune-deployments"
      ]
    },
    "ensure-cf-project:production": {
      "command": "npx wrangler pages project list 2>&1 | grep -qw production-cloud-8-skate-angular || npx wrangler pages project create production-cloud-8-skate-angular --production-branch main"
    },
    "prune-deployments:production": {
      "command": "npx tsx scripts/prune-wrangler-deployments.ts production-cloud-8-skate-angular 10"
    },
    "deploy:production": {
      "command": "npx nx build cloud-8-skate-angular --configuration=production-env && node apps/ui/cloud-8-skate-angular/scripts/generate-sitemap.mjs && npx wrangler pages deploy dist/apps/ui/cloud-8-skate-angular/browser --project-name production-cloud-8-skate-angular",
      "dependsOn": [
        "ensure-cf-project:production",
        "prune-deployments:production"
      ]
    }
  }
}
