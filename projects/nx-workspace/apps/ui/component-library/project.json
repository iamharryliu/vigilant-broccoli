{
  "name": "component-library",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/ui/component-library/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "build": {
      "outputs": [
        "{projectRoot}/{options.outDir}",
        "{workspaceRoot}/dist/component-library"
      ],
      "defaultConfiguration": "production",
      "options": {
        "outDir": "../../../dist/component-library"
      },
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "mode": "production"
        }
      }
    },
    "serve": {
      "defaultConfiguration": "development",
      "configurations": {
        "development": {},
        "production": {}
      }
    },
    "preview": {
      "defaultConfiguration": "development",
      "configurations": {
        "development": {},
        "production": {}
      }
    },
    "serve-static": {
      "executor": "@nx/web:file-server",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "component-library:build",
        "spa": true
      }
    },
    "deploy-github-pages": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "commands": [
          "rm -rf ../../../_site/react-component-library",
          "mkdir -p ../../../_site/react-component-library",
          "cp -R ../../../dist/component-library/. ../../../_site/react-component-library/"
        ],
        "parallel": false,
        "cwd": "{projectRoot}"
      }
    }
  }
}
