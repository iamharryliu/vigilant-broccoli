{
  "name": "small-business-next",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/ui/small-business-next",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/next:build",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/ui/small-business-next",
        "webpack": true
      },
      "configurations": {
        "development": {
          "outputPath": "apps/ui/small-business-next"
        },
        "production": {}
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "defaultConfiguration": "development",
      "options": {
        "command": "NODE_EXTRA_CA_CERTS=./scripts/vault-ca.crt node --import tsx scripts/fetch-secrets.ts --env-file apps/ui/small-business-next/.env.local.example 'cd apps/ui/small-business-next && next dev --port 4200'"
      }
    },
    "serve:no-vault": {
      "executor": "@nx/next:server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "small-business-next:build",
        "dev": true,
        "webpack": true,
        "port": 4201
      },
      "configurations": {
        "development": {
          "buildTarget": "small-business-next:build:development",
          "dev": true
        },
        "production": {
          "buildTarget": "small-business-next:build:production",
          "dev": false
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
