{
  "name": "small-business-next",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/ui/small-business-next",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": [
        "default",
        "^default",
        { "externalDependencies": ["next"] },
        { "dependentTasksOutputFiles": "**/*.d.ts", "transitive": true }
      ],
      "outputs": [
        "{workspaceRoot}/dist/apps/ui/small-business-next/.next/!(cache)/**/*",
        "{workspaceRoot}/dist/apps/ui/small-business-next/.next/!(cache)"
      ],
      "options": {
        "cwd": "apps/ui/small-business-next",
        "tty": false,
        "command": "next build --webpack"
      },
      "configurations": {
        "development": {}
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "defaultConfiguration": "development",
      "options": {
        "command": "NODE_EXTRA_CA_CERTS=./scripts/vault-ca.crt node --import tsx scripts/fetch-secrets.ts --env-file apps/ui/small-business-next/.env.local.example 'cd apps/ui/small-business-next && next dev --port 4200'"
      }
    },
    "serve:no-vault": {
      "executor": "nx:run-commands",
      "defaultConfiguration": "development",
      "options": {
        "cwd": "apps/ui/small-business-next",
        "command": "next dev --webpack --port 4201"
      },
      "configurations": {
        "development": {},
        "production": {}
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
