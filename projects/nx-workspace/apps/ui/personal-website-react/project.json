{
  "name": "personal-website-react",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/ui/personal-website-react/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "pre-build": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "node --import tsx apps/ui/personal-website-react/scripts/download-resume.ts"
          }
        ]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "build": {
      "dependsOn": ["pre-build"],
      "outputs": [
        "{projectRoot}/{options.outDir}",
        "{workspaceRoot}/dist/apps/ui/personal-website-react"
      ],
      "defaultConfiguration": "production",
      "options": {
        "outDir": "../../../dist/apps/ui/personal-website-react"
      },
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "mode": "production"
        },
        "production-env": {
          "mode": "production",
          "fileReplacements": [
            {
              "replace": "apps/ui/personal-website-react/src/environments/environment.ts",
              "with": "apps/ui/personal-website-react/src/environments/environment.production.ts"
            }
          ]
        }
      }
    },
    "serve": {
      "defaultConfiguration": "development",
      "configurations": {
        "development": {},
        "production": {}
      }
    },
    "preview": {
      "defaultConfiguration": "development"
    },
    "ensure-cf-project": {
      "command": "npx wrangler pages project list 2>&1 | grep -qw staging-harryliu-dev-react || npx wrangler pages project create staging-harryliu-dev-react --production-branch main"
    },
    "prune-deployments": {
      "command": "npx tsx scripts/prune-wrangler-deployments.ts staging-harryliu-dev-react 10"
    },
    "deploy": {
      "command": "npx wrangler pages deploy dist/apps/ui/personal-website-react --project-name staging-harryliu-dev-react",
      "dependsOn": ["build", "ensure-cf-project", "prune-deployments"]
    },
    "manual-deploy": {
      "command": "npx wrangler pages deploy dist/apps/ui/personal-website-react --project-name staging-harryliu-dev-react",
      "dependsOn": ["build", "ensure-cf-project", "prune-deployments"]
    },
    "ensure-cf-project:production": {
      "command": "npx wrangler pages project list 2>&1 | grep -qw production-harryliu-dev-react || npx wrangler pages project create production-harryliu-dev-react --production-branch main"
    },
    "prune-deployments:production": {
      "command": "npx tsx scripts/prune-wrangler-deployments.ts production-harryliu-dev-react 10"
    },
    "deploy:production": {
      "command": "npx nx build personal-website-react --configuration=production-env && npx wrangler pages deploy dist/apps/ui/personal-website-react --project-name production-harryliu-dev-react",
      "dependsOn": [
        "ensure-cf-project:production",
        "prune-deployments:production"
      ]
    }
  }
}
