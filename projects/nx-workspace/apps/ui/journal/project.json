{
  "name": "journal",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/ui/journal/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "build": {
      "outputs": [
        "{projectRoot}/{options.outDir}",
        "{workspaceRoot}/dist/apps/ui/journal"
      ],
      "defaultConfiguration": "production",
      "options": {
        "outDir": "../../../dist/apps/ui/journal"
      },
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "mode": "production"
        }
      }
    },
    "serve": {
      "defaultConfiguration": "development",
      "configurations": {
        "development": {},
        "production": {}
      }
    },
    "ensure-cf-project": {
      "command": "npx wrangler pages project list 2>&1 | grep -qw staging-journal || npx wrangler pages project create staging-journal --production-branch main"
    },
    "prune-deployments": {
      "command": "npx tsx scripts/prune-wrangler-deployments.ts staging-journal 10"
    },
    "deploy": {
      "command": "npx wrangler pages deploy dist/apps/ui/journal --project-name staging-journal",
      "dependsOn": ["build", "ensure-cf-project", "prune-deployments"]
    },
    "manual-deploy": {
      "command": "npx wrangler pages deploy dist/apps/ui/journal --project-name staging-journal",
      "dependsOn": ["build", "ensure-cf-project", "prune-deployments"]
    }
  }
}
