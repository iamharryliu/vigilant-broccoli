NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Upstream employee-handler service. If unset, the UI's /api/* routes fall
# back to running the bundled EMPLOYEE_HANDLER_CONFIG_MOCK in-process. If set,
# every /api/* request is proxied to ${EMPLOYEE_HANDLER_URL}${pathname}.
EMPLOYEE_HANDLER_URL=
