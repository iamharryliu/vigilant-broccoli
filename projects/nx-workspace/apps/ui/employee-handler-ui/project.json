{
  "name": "employee-handler-ui",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/ui/employee-handler-ui",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/next:build",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/ui/employee-handler-ui",
        "webpack": true
      },
      "configurations": {
        "development": {
          "outputPath": "apps/ui/employee-handler-ui"
        },
        "production": {}
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "NEXT_PUBLIC_SUPABASE_URL=https://jrdosjjgmsoodpjmjqxx.supabase.co NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_RuDKhGPtVemZN8USy9j0vA_kn42h7S0 nx run employee-handler-ui:serve:dev"
      }
    },
    "serve:mock:e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "concurrently -n service,ui -c blue,green \"nx serve mock-employee-handler-service\" \"EMPLOYEE_HANDLER_URL=http://localhost:3000 nx run employee-handler-ui:serve\""
      }
    },
    "serve:dev": {
      "executor": "@nx/next:server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "employee-handler-ui:build",
        "dev": true,
        "webpack": true
      },
      "configurations": {
        "development": {
          "buildTarget": "employee-handler-ui:build:development",
          "dev": true
        },
        "production": {
          "buildTarget": "employee-handler-ui:build:production",
          "dev": false
        }
      }
    },
    "deploy-container": {
      "dependsOn": ["build"],
      "command": "docker buildx build --platform linux/amd64 -f apps/ui/employee-handler-ui/Dockerfile -t iamharryliu/employee-handler-next:latest -t iamharryliu/employee-handler-next:${COMMIT_SHA:-latest} --push ."
    },
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "VERCEL_PROJECT_ID=staging-employee-handler-ui VERCEL_ORG_ID=team_K8XGLgKfYA0WKlMX80jaVSvg NODE_EXTRA_CA_CERTS=./scripts/vault-ca.crt node --import tsx scripts/deploy-vercel.ts employee-handler-ui production"
      },
      "dependsOn": ["deploy-container"]
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
