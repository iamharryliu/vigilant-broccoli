{
  "name": "employee-handler-ui",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/ui/employee-handler-ui",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": [
        "default",
        "^default",
        { "externalDependencies": ["next"] },
        { "dependentTasksOutputFiles": "**/*.d.ts", "transitive": true }
      ],
      "outputs": [
        "{workspaceRoot}/dist/apps/ui/employee-handler-ui/.next/!(cache)/**/*",
        "{workspaceRoot}/dist/apps/ui/employee-handler-ui/.next/!(cache)"
      ],
      "options": {
        "cwd": "apps/ui/employee-handler-ui",
        "tty": false,
        "command": "next build --webpack"
      },
      "configurations": {
        "development": {}
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "NEXT_PUBLIC_SUPABASE_URL=https://jrdosjjgmsoodpjmjqxx.supabase.co NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_RuDKhGPtVemZN8USy9j0vA_kn42h7S0 nx run employee-handler-ui:serve:dev"
      }
    },
    "serve:mock:e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "concurrently -n service,ui -c blue,green \"nx serve mock-employee-handler-service\" \"EMPLOYEE_HANDLER_URL=http://localhost:3000 nx run employee-handler-ui:serve\""
      }
    },
    "serve:dev": {
      "executor": "nx:run-commands",
      "defaultConfiguration": "development",
      "options": {
        "cwd": "apps/ui/employee-handler-ui",
        "command": "next dev --webpack"
      },
      "configurations": {
        "development": {},
        "production": {}
      }
    },
    "deploy-container": {
      "dependsOn": ["build"],
      "command": "docker buildx build --platform linux/amd64 -f apps/ui/employee-handler-ui/Dockerfile -t iamharryliu/employee-handler-next:latest -t iamharryliu/employee-handler-next:${COMMIT_SHA:-latest} --push ."
    },
    "deploy": {
      "executor": "nx:run-commands",
      "dependsOn": ["deploy-container"],
      "options": {
        "command": "VERCEL_PROJECT_ID=staging-employee-handler-ui VERCEL_ORG_ID=team_K8XGLgKfYA0WKlMX80jaVSvg NODE_EXTRA_CA_CERTS=./scripts/vault-ca.crt node --import tsx scripts/deploy-vercel.ts employee-handler-ui staging"
      }
    },
    "deploy:production": {
      "executor": "nx:run-commands",
      "dependsOn": ["deploy-container"],
      "options": {
        "command": "VERCEL_PROJECT_ID=production-employee-handler-ui VERCEL_ORG_ID=team_K8XGLgKfYA0WKlMX80jaVSvg NODE_EXTRA_CA_CERTS=./scripts/vault-ca.crt node --import tsx scripts/deploy-vercel.ts employee-handler-ui production"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
