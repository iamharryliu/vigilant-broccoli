{
  "name": "docs-md",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/ui/docs-md/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "build": {
      "outputs": [
        "{projectRoot}/{options.outDir}",
        "{workspaceRoot}/dist/docs-md"
      ],
      "defaultConfiguration": "production",
      "options": {
        "outDir": "../../../dist/docs-md"
      },
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "mode": "production"
        }
      }
    },
    "serve": {
      "defaultConfiguration": "development",
      "configurations": {
        "development": {},
        "production": {}
      }
    },
    "deploy-github-pages": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "commands": [
          "rm -rf ../../../_site/docs-md",
          "mkdir -p ../../../_site/docs-md",
          "cp -R ../../../dist/docs-md/. ../../../_site/docs-md/"
        ],
        "parallel": false,
        "cwd": "{projectRoot}"
      }
    }
  }
}
