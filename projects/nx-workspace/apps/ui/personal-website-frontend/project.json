{
  "name": "personal-website-frontend",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/ui/personal-website-frontend/src",
  "tags": [],
  "targets": {
    "pre-build": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "node --import tsx apps/ui/personal-website-frontend/scripts/download-resume.ts && node --import tsx file_structure_to_json.ts ../../notes ./apps/ui/personal-website-frontend/src/assets/md-library/md-library.json && rsync -r --include='*/' --include='*.md' --exclude='*' ../../notes apps/ui/personal-website-frontend/src/assets/md-library/ --delete && rsync -ar --exclude '__init__.py' --include '*/' --include '*.ts' --include '*.go' --include '*.py' --exclude '*' ../grind-75 apps/ui/personal-website-frontend/src/assets/grind-75/ --delete && node --import tsx file_structure_to_json.ts apps/ui/personal-website-frontend/src/assets/grind-75/grind-75/ ./apps/ui/personal-website-frontend/src/assets/grind-75/grind-75.json"
          }
        ]
      }
    },
    "build": {
      "executor": "@angular-devkit/build-angular:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/ui/personal-website-frontend",
        "index": "apps/ui/personal-website-frontend/src/index.html",
        "browser": "apps/ui/personal-website-frontend/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/ui/personal-website-frontend/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          "apps/ui/personal-website-frontend/src/assets",
          {
            "glob": "_redirects",
            "input": "apps/ui/personal-website-frontend/src",
            "output": "/"
          }
        ],
        "styles": [
          "apps/ui/personal-website-frontend/src/styles.scss",
          "node_modules/@fortawesome/fontawesome-free/css/all.css"
        ],
        "scripts": [],
        "aot": true
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "2kb",
              "maximumError": "4kb"
            }
          ],
          "outputHashing": "all"
        },
        "production-env": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "2kb",
              "maximumError": "4kb"
            }
          ],
          "outputHashing": "all",
          "fileReplacements": [
            {
              "replace": "apps/ui/personal-website-frontend/src/environments/environment.ts",
              "with": "apps/ui/personal-website-frontend/src/environments/environment.production.ts"
            }
          ]
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true,
          "fileReplacements": [
            {
              "replace": "apps/ui/personal-website-frontend/src/environments/environment.ts",
              "with": "apps/ui/personal-website-frontend/src/environments/environment.development.ts"
            }
          ]
        }
      },
      "defaultConfiguration": "production",
      "dependsOn": ["pre-build"]
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "personal-website-frontend:build:production"
        },
        "development": {
          "buildTarget": "personal-website-frontend:build:development"
        }
      },
      "defaultConfiguration": "development",
      "continuous": true,
      "options": {
        "proxyConfig": "apps/ui/personal-website-frontend/proxy.conf.json"
      }
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "buildTarget": "personal-website-frontend:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "serve-static": {
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "personal-website-frontend:build",
        "staticFilePath": "dist/apps/ui/personal-website-frontend/browser"
      }
    },
    "ensure-cf-project": {
      "command": "npx wrangler pages project list 2>&1 | grep -qw staging-harryliu-dev-angular || npx wrangler pages project create staging-harryliu-dev-angular --production-branch main"
    },
    "prune-deployments": {
      "command": "npx tsx scripts/prune-wrangler-deployments.ts staging-harryliu-dev-angular 10"
    },
    "deploy": {
      "command": "npx wrangler pages deploy dist/apps/ui/personal-website-frontend/browser --project-name staging-harryliu-dev-angular",
      "dependsOn": ["build", "ensure-cf-project", "prune-deployments"]
    },
    "manual-deploy": {
      "command": "npx wrangler pages deploy dist/apps/ui/personal-website-frontend/browser --project-name staging-harryliu-dev-angular",
      "dependsOn": ["build", "ensure-cf-project", "prune-deployments"]
    },
    "ensure-cf-project:production": {
      "command": "npx wrangler pages project list 2>&1 | grep -qw production-harryliu-dev-angular || npx wrangler pages project create production-harryliu-dev-angular --production-branch main"
    },
    "prune-deployments:production": {
      "command": "npx tsx scripts/prune-wrangler-deployments.ts production-harryliu-dev-angular 10"
    },
    "deploy:production": {
      "command": "npx nx build personal-website-frontend --configuration=production-env && npx wrangler pages deploy dist/apps/ui/personal-website-frontend/browser --project-name production-harryliu-dev-angular",
      "dependsOn": [
        "ensure-cf-project:production",
        "prune-deployments:production"
      ]
    }
  }
}
