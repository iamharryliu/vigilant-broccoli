{
  "name": "vb-manager-next-mobile",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/vb-manager-next-mobile",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": [
        "default",
        "^default",
        { "externalDependencies": ["next"] },
        { "dependentTasksOutputFiles": "**/*.d.ts", "transitive": true }
      ],
      "outputs": [
        "{workspaceRoot}/dist/apps/vb-manager-next-mobile/.next/!(cache)/**/*",
        "{workspaceRoot}/dist/apps/vb-manager-next-mobile/.next/!(cache)"
      ],
      "options": {
        "cwd": "apps/vb-manager-next-mobile",
        "tty": false,
        "command": "next build --webpack"
      },
      "configurations": {
        "development": {}
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "defaultConfiguration": "development",
      "options": {
        "command": "NODE_EXTRA_CA_CERTS=./scripts/vault-ca.crt node --import tsx scripts/fetch-secrets.ts --env-file apps/vb-manager-next-mobile/.env.example 'cd apps/vb-manager-next-mobile && next dev --webpack --port 4200'",
        "env": {
          "VB_EXPRESS_URL": "https://staging-vb-express.fly.dev"
        }
      }
    },
    "serve:no-vault": {
      "executor": "nx:run-commands",
      "defaultConfiguration": "development",
      "options": {
        "cwd": "apps/vb-manager-next-mobile",
        "command": "next dev --webpack --port 4200"
      },
      "configurations": {
        "development": {},
        "production": {}
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "deploy:secrets": {
      "executor": "nx:run-commands",
      "options": {
        "command": "NODE_EXTRA_CA_CERTS=./scripts/vault-ca.crt npx tsx scripts/deploy-flyio-secrets.ts vb-manager-next-mobile staging"
      }
    },
    "deploy": {
      "command": "flyctl deploy --dockerfile ./apps/vb-manager-next-mobile/Dockerfile --config ./deployment-configs/fly-configs/staging-vb-manager-next-mobile.toml --build-arg VB_EXPRESS_URL=https://staging-vb-express.fly.dev",
      "dependsOn": ["build", "lint", "deploy:secrets"]
    },
    "deploy:secrets:production": {
      "executor": "nx:run-commands",
      "options": {
        "command": "NODE_EXTRA_CA_CERTS=./scripts/vault-ca.crt npx tsx scripts/deploy-flyio-secrets.ts vb-manager-next-mobile production"
      }
    },
    "deploy:production": {
      "command": "flyctl deploy --dockerfile ./apps/vb-manager-next-mobile/Dockerfile --config ./deployment-configs/fly-configs/production-vb-manager-next-mobile.toml --build-arg VB_EXPRESS_URL=https://production-vb-express.fly.dev",
      "dependsOn": ["build", "lint", "deploy:secrets:production"]
    }
  }
}
