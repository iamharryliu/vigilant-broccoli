{
  "name": "next-demo",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/next-demo",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/next:build",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/next-demo",
        "webpack": true
      },
      "configurations": {
        "development": {
          "outputPath": "apps/next-demo"
        },
        "production": {}
      }
    },
    "serve:vault": {
      "executor": "nx:run-commands",
      "defaultConfiguration": "development",
      "options": {
        "command": "NODE_EXTRA_CA_CERTS=./scripts/vault-ca.crt node --import tsx scripts/fetch-secrets.ts 'nx serve next-demo'"
      }
    },
    "serve": {
      "executor": "@nx/next:server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "next-demo:build",
        "dev": true,
        "webpack": true
      },
      "configurations": {
        "development": {
          "buildTarget": "next-demo:build:development",
          "dev": true
        },
        "production": {
          "buildTarget": "next-demo:build:production",
          "dev": false
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "deploy:secrets": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "vercel env add NEXT_PUBLIC_SUPABASE_URL production <<< 'https://jrdosjjgmsoodpjmjqxx.supabase.co'",
          "vercel env add NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY production <<< 'sb_publishable_RuDKhGPtVemZN8USy9j0vA_kn42h7S0'",
          "vercel env add NEXT_PUBLIC_APP_URL production <<< 'https://vb-next-demo.vercel.app/'"
        ],
        "parallel": false
      }
    }
  }
}
