{
  "name": "next-demo",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/next-demo",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/next:build",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/next-demo",
        "webpack": true
      },
      "configurations": {
        "development": {
          "outputPath": "apps/next-demo"
        },
        "production": {}
      }
    },
    "serve:vault": {
      "executor": "nx:run-commands",
      "defaultConfiguration": "development",
      "options": {
        "command": "NODE_EXTRA_CA_CERTS=./scripts/vault-ca.crt node --import tsx scripts/fetch-secrets.ts --env-file apps/next-demo/.env.local.example --env-file scripts/.env.scripts.example 'node --import tsx scripts/migrate.ts --migrations-dir=apps/next-demo/supabase/migrations && nx serve next-demo'"
      }
    },
    "serve": {
      "executor": "@nx/next:server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "next-demo:build",
        "dev": true,
        "webpack": true
      },
      "configurations": {
        "development": {
          "buildTarget": "next-demo:build:development",
          "dev": true
        },
        "production": {
          "buildTarget": "next-demo:build:production",
          "dev": false
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "deploy:secrets": {
      "executor": "nx:run-commands",
      "options": {
        "command": "NODE_EXTRA_CA_CERTS=./scripts/vault-ca.crt node --import tsx scripts/deploy-vercel-secrets.ts next-demo production"
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'Vercel deployment is triggered automatically on push. Running secrets sync only.'"
      },
      "dependsOn": ["deploy:secrets"]
    }
  }
}
