{
  "name": "office-presence-socket-server-demo",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/office-presence-socket-server-demo/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "platform": "node",
        "outputPath": "dist/apps/office-presence-socket-server-demo",
        "format": ["cjs"],
        "bundle": true,
        "thirdParty": true,
        "main": "apps/office-presence-socket-server-demo/src/main.ts",
        "tsConfig": "apps/office-presence-socket-server-demo/tsconfig.app.json",
        "assets": ["apps/office-presence-socket-server-demo/src/assets"],
        "esbuildOptions": {
          "sourcemap": true,
          "outExtension": {
            ".js": ".js"
          }
        }
      },
      "configurations": {
        "development": {},
        "production": {
          "esbuildOptions": {
            "sourcemap": false,
            "outExtension": {
              ".js": ".js"
            }
          }
        }
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "office-presence-socket-server-demo:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "office-presence-socket-server-demo:build:development"
        },
        "production": {
          "buildTarget": "office-presence-socket-server-demo:build:production"
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "deploy-container": {
      "dependsOn": ["build"],
      "command": "docker buildx build --platform linux/amd64 -f apps/office-presence-socket-server-demo/Dockerfile -t iamharryliu/office-presence-socket-server-demo:latest -t iamharryliu/office-presence-socket-server-demo:${COMMIT_SHA:-latest} --push dist/apps/office-presence-socket-server-demo"
    }
  }
}
