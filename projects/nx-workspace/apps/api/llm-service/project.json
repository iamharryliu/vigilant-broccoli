{
  "name": "llm-service",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/api/llm-service/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "target": "node",
        "compiler": "tsc",
        "outputPath": "dist/apps/api/llm-service",
        "main": "apps/api/llm-service/src/main.ts",
        "tsConfig": "apps/api/llm-service/tsconfig.app.json",
        "webpackConfig": "apps/api/llm-service/webpack.config.js",
        "generatePackageJson": true
      },
      "configurations": {
        "development": {
          "outputHashing": "none"
        },
        "production": {}
      }
    },
    "prune-lockfile": {
      "dependsOn": ["build"],
      "cache": true,
      "executor": "@nx/js:prune-lockfile",
      "outputs": [
        "{workspaceRoot}/dist/apps/api/llm-service/package.json",
        "{workspaceRoot}/dist/apps/api/llm-service/package-lock.json"
      ],
      "options": {
        "buildTarget": "build"
      }
    },
    "copy-workspace-modules": {
      "dependsOn": ["build"],
      "cache": true,
      "outputs": [
        "{workspaceRoot}/dist/apps/api/llm-service/workspace_modules"
      ],
      "executor": "@nx/js:copy-workspace-modules",
      "options": {
        "buildTarget": "build"
      }
    },
    "prune": {
      "dependsOn": ["prune-lockfile", "copy-workspace-modules"],
      "executor": "nx:noop"
    },
    "smoke": {
      "dependsOn": ["prune"],
      "executor": "nx:run-commands",
      "options": {
        "command": "bash scripts/shell/smoke-dist.sh dist/apps/api/llm-service"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "defaultConfiguration": "development",
      "options": {
        "command": "NODE_EXTRA_CA_CERTS=./scripts/vault-ca.crt npx tsx scripts/fetch-secrets.ts 'nx serve:no-vault llm-service'"
      }
    },
    "serve:no-vault": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "llm-service:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "llm-service:build:development"
        },
        "production": {
          "buildTarget": "llm-service:build:production"
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "deploy:secrets": {
      "executor": "nx:run-commands",
      "options": {
        "command": "NODE_EXTRA_CA_CERTS=./scripts/vault-ca.crt npx tsx scripts/deploy-flyio-secrets.ts llm-service staging"
      }
    },
    "deploy": {
      "command": "flyctl deploy --dockerfile ./apps/api/llm-service/Dockerfile --config ./deployment-configs/fly-configs/staging-llm-service.toml",
      "dependsOn": ["build", "lint", "prune", "smoke", "deploy:secrets"]
    },
    "deploy:secrets:production": {
      "executor": "nx:run-commands",
      "options": {
        "command": "NODE_EXTRA_CA_CERTS=./scripts/vault-ca.crt npx tsx scripts/deploy-flyio-secrets.ts llm-service production"
      }
    },
    "deploy:production": {
      "command": "flyctl deploy --dockerfile ./apps/api/llm-service/Dockerfile --config ./deployment-configs/fly-configs/production-llm-service.toml",
      "dependsOn": [
        "build",
        "lint",
        "prune",
        "smoke",
        "deploy:secrets:production"
      ]
    }
  }
}
