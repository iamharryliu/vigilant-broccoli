{
  "name": "email-service",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/api/email-service/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "platform": "node",
        "outputPath": "dist/apps/api/email-service",
        "format": ["cjs"],
        "bundle": true,
        "main": "apps/api/email-service/src/main.ts",
        "tsConfig": "apps/api/email-service/tsconfig.app.json",
        "assets": ["apps/api/email-service/src/assets"],
        "esbuildOptions": {
          "sourcemap": true,
          "outExtension": {
            ".js": ".js"
          }
        }
      },
      "configurations": {
        "development": {},
        "production": {
          "esbuildOptions": {
            "sourcemap": false,
            "outExtension": {
              ".js": ".js"
            }
          }
        }
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "email-service:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "email-service:build:development"
        },
        "production": {
          "buildTarget": "email-service:build:production"
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "deploy-container": {
      "dependsOn": ["build"],
      "command": "docker build -f apps/api/email-service/Dockerfile -t iamharryliu/email-service:latest -t iamharryliu/email-service:${COMMIT_SHA:-latest} dist/apps/api/email-service && docker push iamharryliu/email-service:latest && docker push iamharryliu/email-service:${COMMIT_SHA:-latest}"
    }
  }
}
