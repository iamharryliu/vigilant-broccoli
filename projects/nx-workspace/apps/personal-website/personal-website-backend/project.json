{
  "name": "personal-website-backend",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/personal-website/personal-website-backend/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "platform": "node",
        "outputPath": "dist/apps/personal-website/personal-website-backend",
        "format": ["cjs"],
        "bundle": false,
        "main": "apps/personal-website/personal-website-backend/src/main.ts",
        "tsConfig": "apps/personal-website/personal-website-backend/tsconfig.app.json",
        "assets": ["apps/personal-website/personal-website-backend/src/assets"],
        "generatePackageJson": true,
        "esbuildOptions": {
          "sourcemap": true,
          "outExtension": {
            ".js": ".js"
          }
        }
      },
      "configurations": {
        "development": {},
        "production": {
          "generateLockfile": true,
          "esbuildOptions": {
            "sourcemap": false,
            "outExtension": {
              ".js": ".js"
            }
          }
        }
      }
    },
    "prune-lockfile": {
      "dependsOn": ["build"],
      "cache": true,
      "executor": "@nx/js:prune-lockfile",
      "outputs": [
        "{workspaceRoot}/dist/apps/personal-website/personal-website-backend/package.json",
        "{workspaceRoot}/dist/apps/personal-website/personal-website-backend/package-lock.json"
      ],
      "options": {
        "buildTarget": "build"
      }
    },
    "copy-workspace-modules": {
      "dependsOn": ["build"],
      "cache": true,
      "outputs": [
        "{workspaceRoot}/dist/apps/personal-website/personal-website-backend/workspace_modules"
      ],
      "executor": "@nx/js:copy-workspace-modules",
      "options": {
        "buildTarget": "build"
      }
    },
    "prune": {
      "dependsOn": ["prune-lockfile", "copy-workspace-modules"],
      "executor": "nx:noop"
    },
    "serve": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node --import tsx scripts/fetch-secrets.ts 'node dist/apps/personal-website/personal-website-backend/main.js'"
      }
    },
    "serve:no-vault": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "personal-website-backend:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "personal-website-backend:build:development"
        },
        "production": {
          "buildTarget": "personal-website-backend:build:production"
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "docker:build": {
      "dependsOn": ["build", "prune"]
    },
    "deploy:secrets": {
      "executor": "nx:run-commands",
      "options": {
        "command": "NODE_EXTRA_CA_CERTS=./scripts/vault-ca.crt tsx scripts/deploy-flyio-secrets.ts personal-website-backend"
      }
    },
    "deploy": {
      "dependsOn": ["build", "lint", "deploy:secrets"],
      "executor": "nx:run-commands",
      "options": {
        "command": "flyctl deploy --dockerfile ./apps/personal-website/personal-website-backend/Dockerfile --config ./deployment-configs/fly-configs/personal-website-backend.toml"
      }
    }
  }
}
