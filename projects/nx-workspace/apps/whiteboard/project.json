{
  "name": "whiteboard",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/whiteboard",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/next:build",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/whiteboard",
        "webpack": true
      },
      "configurations": {
        "development": {
          "outputPath": "apps/whiteboard"
        },
        "production": {}
      }
    },
    "serve": {
      "executor": "@nx/next:server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "whiteboard:build",
        "dev": true,
        "webpack": true
      },
      "configurations": {
        "development": {
          "buildTarget": "whiteboard:build:development",
          "dev": true
        },
        "production": {
          "buildTarget": "whiteboard:build:production",
          "dev": false
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "VERCEL_PROJECT_ID=staging-whiteboard VERCEL_ORG_ID=team_K8XGLgKfYA0WKlMX80jaVSvg NODE_EXTRA_CA_CERTS=./scripts/vault-ca.crt node --import tsx scripts/deploy-vercel.ts whiteboard staging"
      }
    },
    "deploy:production": {
      "executor": "nx:run-commands",
      "options": {
        "command": "VERCEL_PROJECT_ID=production-whiteboard VERCEL_ORG_ID=team_K8XGLgKfYA0WKlMX80jaVSvg NODE_EXTRA_CA_CERTS=./scripts/vault-ca.crt node --import tsx scripts/deploy-vercel.ts whiteboard production"
      }
    }
  }
}
