{
  "name": "email-consumer",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/consumers/email-consumer/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "platform": "node",
        "outputPath": "dist/apps/consumers/email-consumer",
        "format": ["cjs"],
        "bundle": true,
        "main": "apps/consumers/email-consumer/src/main.ts",
        "tsConfig": "apps/consumers/email-consumer/tsconfig.app.json",
        "assets": ["apps/consumers/email-consumer/src/assets"],
        "generatePackageJson": true,
        "esbuildOptions": {
          "sourcemap": true,
          "outExtension": {
            ".js": ".js"
          }
        }
      },
      "configurations": {
        "development": {},
        "production": {
          "generateLockfile": true,
          "esbuildOptions": {
            "sourcemap": false,
            "outExtension": {
              ".js": ".js"
            }
          }
        }
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "email-consumer:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "email-consumer:build:development"
        },
        "production": {
          "buildTarget": "email-consumer:build:production"
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "deploy": {
      "dependsOn": ["build"],
      "command": "docker buildx build --platform linux/arm64 -t iamharryliu/email-consumer:latest -t iamharryliu/email-consumer:${COMMIT_SHA:-latest} --push -f ./apps/consumers/email-consumer/Dockerfile ."
    },
    "restart": {
      "dependsOn": ["deploy"],
      "command": "ssh -i ~/.ssh/id_ed25519 ubuntu@$(cd ../../terraform && terraform output -raw rabbitmq_public_ip) 'docker pull iamharryliu/email-consumer:latest && docker compose -f /opt/rabbitmq/docker-compose.yml up -d --no-deps email-consumer'"
    }
  }
}
