{
  "name": "cloud8skate-sanity",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "{projectRoot}",
  "projectType": "application",
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node_modules/.bin/sanity dev",
        "cwd": "{projectRoot}"
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node_modules/.bin/sanity deploy",
        "cwd": "{projectRoot}"
      }
    },
    "deploy-graphql": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node_modules/.bin/sanity graphql deploy",
        "cwd": "{projectRoot}"
      }
    }
  }
}
